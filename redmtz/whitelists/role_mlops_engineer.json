{
  "role": "mlops_engineer",
  "description": "MLOps Engineer — model training, experiment tracking, S3 data access, Docker builds. No IAM mutations, no VPC changes, no database DDL.",
  "version": "2.0.0",
  "allowed_patterns": [
    {
      "pattern_id": "ALLOW_S3_OPS",
      "description": "aws s3 ls/cp/sync — read and write scoped bucket data",
      "regex": "(?i)\\baws\\s+s3\\s+(ls|cp|sync)\\b",
      "domain": "system",
      "risk_level": "MEDIUM",
      "examples": ["aws s3 ls s3://my-bucket/data/", "aws s3 cp model.pkl s3://my-bucket/models/", "aws s3 sync ./output s3://my-bucket/runs/"]
    },
    {
      "pattern_id": "ALLOW_SAGEMAKER_READ",
      "description": "SageMaker describe/list — read training jobs and endpoints",
      "regex": "(?i)\\baws\\s+sagemaker\\s+(describe-|list-)",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["aws sagemaker describe-training-job --training-job-name my-job", "aws sagemaker list-training-jobs", "aws sagemaker list-models"]
    },
    {
      "pattern_id": "ALLOW_DOCKER_BUILD_TAG",
      "description": "docker build/tag — build and tag container images",
      "regex": "(?i)\\bdocker\\s+(build|tag)\\b",
      "domain": "system",
      "risk_level": "MEDIUM",
      "examples": ["docker build -t my-training-image .", "docker tag my-image:latest my-repo:v1"]
    },
    {
      "pattern_id": "ALLOW_DOCKER_READ",
      "description": "docker ps/images/logs/inspect — read container state",
      "regex": "(?i)\\bdocker\\s+(ps|images|logs|inspect)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["docker images", "docker ps -a", "docker logs my-container"]
    },
    {
      "pattern_id": "ALLOW_PYTHON_RUN",
      "description": "python script execution — run training and evaluation scripts",
      "regex": "(?i)\\bpython3?\\s+\\S+\\.py\\b",
      "domain": "system",
      "risk_level": "MEDIUM",
      "examples": ["python train.py --epochs 10", "python3 evaluate.py --model-path ./output"]
    },
    {
      "pattern_id": "ALLOW_PIP_READ",
      "description": "pip list/show/freeze — read-only package inspection (no install)",
      "regex": "(?i)\\bpip3?\\s+(list|show|freeze)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["pip list", "pip show torch", "pip freeze > requirements.txt"]
    },
    {
      "pattern_id": "ALLOW_GIT_OPS",
      "description": "git status/log/diff/commit/push — standard git workflow (no force push)",
      "regex": "(?i)\\bgit\\s+(status|log|diff|show|branch|remote|fetch|pull|push|commit|add)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["git status", "git log --oneline -10", "git commit -m 'update model'", "git push origin main"]
    },
    {
      "pattern_id": "ALLOW_SELECT_WHERE",
      "description": "SQL SELECT with WHERE — scoped feature store or metadata queries",
      "regex": "(?i)\\bSELECT\\b.+\\bFROM\\b.+\\bWHERE\\b",
      "domain": "database",
      "risk_level": "MEDIUM",
      "examples": ["SELECT * FROM experiments WHERE run_id = '123'"]
    },
    {
      "pattern_id": "ALLOW_CLOUDWATCH_METRICS",
      "description": "CloudWatch metrics — model performance and endpoint monitoring",
      "regex": "(?i)\\baws\\s+cloudwatch\\s+get-metric",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["aws cloudwatch get-metric-statistics --metric-name Invocations"]
    }
  ]
}
