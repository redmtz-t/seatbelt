{
  "role": "junior_admin",
  "description": "Junior System Administrator — read-only operations only. Discovery and monitoring. No writes, no executions, no infrastructure changes. Implicit deny catches everything else.",
  "version": "2.0.0",
  "allowed_patterns": [
    {
      "pattern_id": "ALLOW_SHELL_READ",
      "description": "Standard read/inspect shell commands",
      "regex": "(?i)^\\s*(ls|cat|grep|head|tail|wc|df|du|free|top|ps|whoami|hostname|date|uptime)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["ls -la", "cat /var/log/syslog", "grep ERROR log.txt", "head -20 file.txt", "tail -f app.log", "wc -l data.csv", "df -h", "du -sh /var/log/*", "free -h", "ps aux", "whoami", "hostname", "date", "uptime"]
    },
    {
      "pattern_id": "ALLOW_KUBECTL_READ",
      "description": "kubectl get/logs — read-only cluster access",
      "regex": "(?i)\\bkubectl\\s+(get|logs)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["kubectl get pods -A", "kubectl get nodes", "kubectl logs my-pod"]
    },
    {
      "pattern_id": "ALLOW_GIT_READ",
      "description": "git read operations only — no commit, no push",
      "regex": "(?i)\\bgit\\s+(status|log|diff|show|branch)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["git status", "git log --oneline -5", "git diff HEAD"]
    },
    {
      "pattern_id": "ALLOW_PING",
      "description": "ping — network connectivity check",
      "regex": "(?i)^\\s*ping\\b",
      "domain": "network",
      "risk_level": "LOW",
      "examples": ["ping 8.8.8.8", "ping -c 4 google.com"]
    },
    {
      "pattern_id": "ALLOW_CURL_GET",
      "description": "curl GET/HEAD only — read-only HTTP",
      "regex": "(?i)\\bcurl\\s+(?!.*(-d\\b|--data\\b|-X\\s*(POST|PUT|DELETE|PATCH)\\b|--request\\s*(POST|PUT|DELETE|PATCH)\\b|-F\\b|--form\\b|-T\\b|--upload-file\\b))\\S+",
      "domain": "network",
      "risk_level": "LOW",
      "examples": ["curl -I https://example.com", "curl -s https://api.example.com/health"]
    }
  ]
}
