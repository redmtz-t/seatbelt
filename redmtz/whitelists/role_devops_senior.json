{
  "role": "devops_senior",
  "description": "Senior DevOps Engineer — Kubernetes, Terraform, Docker, Git. Read + analysis + scoped execution. No destroy, no IAM mutations, no database DDL.",
  "version": "2.0.0",
  "allowed_patterns": [
    {
      "pattern_id": "ALLOW_KUBECTL_READ",
      "description": "kubectl get/describe/logs/top — read cluster state",
      "regex": "(?i)\\bkubectl\\s+(get|describe|logs|top)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["kubectl get pods -A", "kubectl describe pod my-pod", "kubectl logs my-pod", "kubectl top nodes"]
    },
    {
      "pattern_id": "ALLOW_TERRAFORM_READ",
      "description": "terraform plan/show/validate/output — read and preview infrastructure",
      "regex": "(?i)\\bterraform\\s+(plan|show|validate|output|state\\s+list)\\b",
      "domain": "system",
      "risk_level": "MEDIUM",
      "examples": ["terraform plan", "terraform show", "terraform validate", "terraform output", "terraform state list"]
    },
    {
      "pattern_id": "ALLOW_DOCKER_READ",
      "description": "docker ps/images/logs/inspect — read container state",
      "regex": "(?i)\\bdocker\\s+(ps|images|logs|inspect)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["docker ps -a", "docker images", "docker logs my-container", "docker inspect my-container"]
    },
    {
      "pattern_id": "ALLOW_GIT_OPS",
      "description": "git status/log/diff/pull/push/commit — standard git workflow (no force push)",
      "regex": "(?i)\\bgit\\s+(status|log|diff|show|branch|remote|fetch|pull|push|commit|add)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["git status", "git log --oneline -10", "git diff HEAD", "git commit -m 'fix'", "git push origin main"]
    },
    {
      "pattern_id": "ALLOW_SHELL_READ",
      "description": "Standard read/inspect shell commands",
      "regex": "(?i)^\\s*(ls|cat|grep|find|head|tail|wc|df|du|free|top|ps|whoami|hostname|date|uptime)\\b",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["ls -la", "cat /var/log/syslog", "grep ERROR log.txt", "head -20 file.txt", "whoami", "hostname", "free -h", "df -h"]
    },
    {
      "pattern_id": "ALLOW_SELECT_WHERE",
      "description": "SQL SELECT with WHERE clause — scoped read query",
      "regex": "(?i)\\bSELECT\\b.+\\bFROM\\b.+\\bWHERE\\b",
      "domain": "database",
      "risk_level": "MEDIUM",
      "examples": ["SELECT id, name FROM users WHERE id = 42", "SELECT * FROM orders WHERE status = 'pending'"]
    },
    {
      "pattern_id": "ALLOW_NET_DIAG",
      "description": "Network diagnostics — ping, traceroute, dig, nslookup",
      "regex": "(?i)^\\s*(ping|traceroute|dig|nslookup)\\b",
      "domain": "network",
      "risk_level": "LOW",
      "examples": ["ping 8.8.8.8", "traceroute google.com", "dig example.com", "nslookup example.com"]
    },
    {
      "pattern_id": "ALLOW_CURL_GET",
      "description": "curl GET/HEAD only — no POST with data flags",
      "regex": "(?i)\\bcurl\\s+(?!.*(-d\\b|--data\\b|-X\\s*(POST|PUT|DELETE|PATCH)\\b|--request\\s*(POST|PUT|DELETE|PATCH)\\b|-F\\b|--form\\b|-T\\b|--upload-file\\b))\\S+",
      "domain": "network",
      "risk_level": "LOW",
      "examples": ["curl -I https://example.com", "curl -s https://api.example.com/health"]
    },
    {
      "pattern_id": "ALLOW_AWS_READ",
      "description": "AWS describe/list — read-only AWS operations",
      "regex": "(?i)\\baws\\s+\\w+\\s+(describe-|list-|get-metric)",
      "domain": "system",
      "risk_level": "LOW",
      "examples": ["aws ec2 describe-instances", "aws s3api list-buckets", "aws cloudwatch get-metric-statistics"]
    }
  ]
}
